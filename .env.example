# ---- LLM providers ----
# Pick one (or both). Your DECISIONS.md should explain which you chose and why.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Supabase (local dev defaults) ----
# Run `pnpm supabase status` after `pnpm supabase start` to print these values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site-wide HTTP Basic Auth password ----
# Defaults to "oliveapp.com" if unset. Username is ignored.
SITE_PASSWORD=
